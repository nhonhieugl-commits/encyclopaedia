# Bách Khoa Toàn Thư Ops — Environment Variables
# Copy file này thành .env và điền giá trị thực

# ============================================================
# BẮT BUỘC
# ============================================================

# API Key — Anthropic hoặc GreenNode
# Anthropic: https://console.anthropic.com  (bắt đầu bằng sk-ant-)
# GreenNode: console GreenNode              (bắt đầu bằng vn-)
ANTHROPIC_API_KEY=your-api-key-here

# Base URL — chỉ cần set khi dùng GreenNode (để trống nếu dùng Anthropic)
# GreenNode endpoint: https://api.greennode.ai/v1
ANTHROPIC_BASE_URL=

# JWT Secret — chuỗi ngẫu nhiên >= 32 ký tự
# Tạo bằng: openssl rand -hex 32
JWT_SECRET=18d83aa0a2e6d86f0c13fdb753744cf637b99bcc3caed161ff5f6207afdf9636

# ============================================================
# TÙY CHỌN (có giá trị mặc định)
# ============================================================

# Server
PORT=3000
NODE_ENV=development   # production khi deploy

# AI Model
MODEL=claude-opus-4-5
MAX_TOKENS=4096

# Auth
JWT_EXPIRES_IN=8h   # Hỗ trợ: 30m, 8h, 1d, 7d

# Storage
DB_PATH=./data/ops.db
UPLOAD_DIR=./data/uploads
MAX_FILE_SIZE_MB=20
